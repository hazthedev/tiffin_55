---
interface Props {
  variant?: 'primary' | 'outline' | 'ghost' | 'chrome';
  href?: string;
  class?: string;
  [key: string]: any;
}

const { variant = 'primary', href, class: className = '', ...rest } = Astro.props;

const base = 'group relative inline-flex items-center justify-center gap-2 px-6 py-3 font-display text-xs sm:text-sm uppercase tracking-[0.18em] transition-all duration-200 chrome-shine select-none';

const variants: Record<string, string> = {
  primary:
    'bg-turmeric text-ink-blue border-2 border-ink-blue shadow-block-ink hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[9px_9px_0_0_#0E1430] active:translate-x-[2px] active:translate-y-[2px] active:shadow-[2px_2px_0_0_#0E1430]',
  outline:
    'bg-cream-paper text-ink-blue border-2 border-ink-blue shadow-block-cobalt hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-[9px_9px_0_0_#1c3aa9] active:translate-x-[2px] active:translate-y-[2px]',
  ghost:
    'bg-transparent text-ink-blue hover:text-chili',
  chrome:
    'chrome-rim text-ink-blue border-2 border-ink-blue hover:-translate-y-[1px]',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button class={classes} {...rest}>
    <slot />
  </button>
)}
