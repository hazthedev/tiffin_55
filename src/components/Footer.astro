---
import Container from './Container.astro';
import Divider from './Divider.astro';
---

<footer class="bg-coal-brown border-t border-concrete-grey/20">
  <Container>
    <div class="py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="font-display text-2xl font-bold text-cream tracking-tight">Tiffin 55</a>
        <p class="mt-3 text-sm text-cream/60 leading-relaxed">
          55, Jalan Wangsa Delima 5<br />
          Wangsa Maju, 53300 Kuala Lumpur
        </p>
        <p class="mt-4 text-sm font-mono text-copper">11:00AM – 3:00AM everyday</p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em] text-cream/40 mb-4">Navigate</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-cream/70 hover:text-copper transition-colors">Home</a></li>
          <li><a href="/menu" class="text-sm text-cream/70 hover:text-copper transition-colors">Menu</a></li>
          <li><a href="/story" class="text-sm text-cream/70 hover:text-copper transition-colors">Our Story</a></li>
          <li><a href="/story#visit" class="text-sm text-cream/70 hover:text-copper transition-colors">Visit Us</a></li>
        </ul>
      </div>

      <!-- Order & Social -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em] text-cream/40 mb-4">Order Online</h3>
        <ul class="space-y-3">
          <li>
            <a href="https://foodpanda.my" target="_blank" rel="noopener" class="text-sm text-cream/70 hover:text-copper transition-colors">FoodPanda</a>
          </li>
          <li>
            <a href="https://grab.com/my/food" target="_blank" rel="noopener" class="text-sm text-cream/70 hover:text-copper transition-colors">GrabFood</a>
          </li>
          <li>
            <a href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '60123456789'}`} target="_blank" rel="noopener" class="text-sm text-cream/70 hover:text-copper transition-colors">WhatsApp</a>
          </li>
        </ul>
        <div class="flex gap-4 mt-6">
          <a href="https://instagram.com/tiffin55" target="_blank" rel="noopener" aria-label="Instagram" class="text-cream/50 hover:text-copper transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://facebook.com/tiffin55" target="_blank" rel="noopener" aria-label="Facebook" class="text-cream/50 hover:text-copper transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="https://tiktok.com/@tiffin55" target="_blank" rel="noopener" aria-label="TikTok" class="text-cream/50 hover:text-copper transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          </a>
        </div>
      </div>
    </div>

    <Divider />

    <div class="py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-accent text-lg text-copper/80">Made with love in Wangsa Maju. Stay late.</p>
      <p class="text-xs text-cream/30">&copy; {new Date().getFullYear()} Tiffin 55. All rights reserved.</p>
    </div>
  </Container>
</footer>
