---
import Container from './Container.astro';
---

<footer class="relative bg-ink-blue border-t-4 border-turmeric overflow-hidden">
  <div class="absolute inset-0 bg-halftone-cobalt opacity-20"></div>

  <!-- Top mosaic stripe -->
  <div class="h-2 bg-tile-mosaic"></div>

  <Container class="relative">
    <div class="py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-2">
          <span class="chrome-rim inline-flex items-center justify-center w-10 h-10 border-2 border-ink-blue font-display text-base">55</span>
          <span class="font-display text-2xl text-cream-paper tracking-tight">TIFFIN<span class="text-chili">·</span>55</span>
        </a>
        <p class="mt-4 text-sm text-cream-paper/70 leading-relaxed font-medium">
          55, Jalan Wangsa Delima 5<br />
          Wangsa Maju, 53300 Kuala Lumpur
        </p>
        <p class="mt-4 inline-block stamp text-turmeric !bg-ink-blue !text-turmeric">11AM – 3AM · DAILY</p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-[10px] font-display uppercase tracking-[0.22em] text-turmeric mb-5">Navigate</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-cream-paper/80 hover:text-turmeric transition-colors font-medium">Home</a></li>
          <li><a href="/menu" class="text-sm text-cream-paper/80 hover:text-turmeric transition-colors font-medium">Menu</a></li>
          <li><a href="/story" class="text-sm text-cream-paper/80 hover:text-turmeric transition-colors font-medium">Our Story</a></li>
          <li><a href="/story#visit" class="text-sm text-cream-paper/80 hover:text-turmeric transition-colors font-medium">Visit Us</a></li>
        </ul>
      </div>

      <!-- Order & Social -->
      <div>
        <h3 class="text-[10px] font-display uppercase tracking-[0.22em] text-turmeric mb-5">Order Online</h3>
        <ul class="space-y-3">
          <li>
            <a href="https://foodpanda.my" target="_blank" rel="noopener" class="text-sm text-cream-paper/80 hover:text-chili transition-colors font-medium">FoodPanda</a>
          </li>
          <li>
            <a href="https://grab.com/my/food" target="_blank" rel="noopener" class="text-sm text-cream-paper/80 hover:text-chili transition-colors font-medium">GrabFood</a>
          </li>
          <li>
            <a href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '60123456789'}`} target="_blank" rel="noopener" class="text-sm text-cream-paper/80 hover:text-chili transition-colors font-medium">WhatsApp</a>
          </li>
        </ul>
        <div class="flex gap-3 mt-6">
          <a href="https://instagram.com/tiffin55" target="_blank" rel="noopener" aria-label="Instagram" class="w-10 h-10 inline-flex items-center justify-center bg-cream-paper text-ink-blue border-2 border-cream-paper hover:bg-turmeric hover:border-turmeric transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://facebook.com/tiffin55" target="_blank" rel="noopener" aria-label="Facebook" class="w-10 h-10 inline-flex items-center justify-center bg-cream-paper text-ink-blue border-2 border-cream-paper hover:bg-turmeric hover:border-turmeric transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="https://tiktok.com/@tiffin55" target="_blank" rel="noopener" aria-label="TikTok" class="w-10 h-10 inline-flex items-center justify-center bg-cream-paper text-ink-blue border-2 border-cream-paper hover:bg-turmeric hover:border-turmeric transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t-2 border-cream-paper/20 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-accent text-xl text-turmeric">Made with love in Wangsa Maju. Stay late.</p>
      <p class="text-xs text-cream-paper/40 font-mono">&copy; {new Date().getFullYear()} Tiffin 55. All rights reserved.</p>
    </div>
  </Container>
</footer>
