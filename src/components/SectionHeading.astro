---
interface Props {
  eyebrow?: string;
  headline: string;
  subhead?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const { eyebrow, headline, subhead, align = 'center', light = false } = Astro.props;

const alignClass = align === 'center' ? 'text-center' : 'text-left';
const textColor = light ? 'text-coal-brown' : 'text-cream';
const eyebrowColor = light ? 'text-copper' : 'text-copper';
const subheadColor = light ? 'text-coal-brown/80' : 'text-cream/70';
---

<div class={`${alignClass} ${textColor}`}>
  {eyebrow && (
    <p class={`text-xs font-semibold uppercase tracking-[0.2em] ${eyebrowColor} mb-3`}>
      {eyebrow}
    </p>
  )}
  <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
    {headline}
  </h2>
  {subhead && (
    <p class={`mt-4 text-base sm:text-lg max-w-2xl ${align === 'center' ? 'mx-auto' : ''} ${subheadColor}`}>
      {subhead}
    </p>
  )}
</div>
