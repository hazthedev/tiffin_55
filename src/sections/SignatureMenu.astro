---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollReveal from '../components/ScrollReveal';

const signatures = [
  {
    name: 'Tiffin Set Kampung',
    desc: 'Three tiers of rice, lauk, and sambal. Choose your combo.',
    price: 18.90,
    image: '/images/food/tiffin-set.jpg',
  },
  {
    name: 'Aglio Olio',
    desc: 'Garlic, olive oil, chilli flakes, and parmesan. Simple and addictive.',
    price: 16.90,
    image: '/images/food/aglio-olio.jpg',
  },
  {
    name: 'Caramel Latte',
    desc: 'Smooth espresso with caramel and steamed milk. Our bestseller.',
    price: 11.90,
    image: '/images/food/caramel-latte.jpg',
  },
  {
    name: 'Pancake Tembam',
    desc: 'Fluffy thick pancakes with butter and maple syrup.',
    price: 12.90,
    image: '/images/food/pancake-tembam.jpg',
  },
  {
    name: 'Lamb Chop',
    desc: 'Grilled lamb shoulder with black pepper sauce. Under RM20.',
    price: 19.90,
    image: '/images/food/lamb-chop.jpg',
  },
  {
    name: 'Roti Bakar Classic',
    desc: 'Thick toast with butter and kaya. The ultimate midnight snack.',
    price: 5.90,
    image: '/images/food/roti-bakar.jpg',
  },
];
---

<section class="py-16 sm:py-24 bg-coal-brown">
  <Container>
    <ScrollReveal client:load>
    <SectionHeading
      eyebrow="FROM THE MENU"
      headline="The ones they keep ordering."
      align="center"
    />
    </ScrollReveal>
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {signatures.map((item) => (
        <a href="/menu" class="group block rounded-sm overflow-hidden bg-charcoal border border-concrete-grey/10 hover:border-copper/30 transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(197,100,45,0.12)]">
          <div class="aspect-[4/3] overflow-hidden bg-coal-brown">
            <img src={item.image} alt={item.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <h3 class="font-display text-lg font-semibold text-cream group-hover:text-copper transition-colors">{item.name}</h3>
              <span class="font-mono text-sm text-copper shrink-0">RM {item.price.toFixed(2)}</span>
            </div>
            <p class="mt-2 text-sm text-cream/60 leading-relaxed">{item.desc}</p>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-10 text-center">
      <ScrollReveal client:load delay={0.2}>
      <a href="/menu" class="inline-flex items-center gap-2 text-sm font-medium text-copper hover:text-cream transition-colors">
        View full menu
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
      </ScrollReveal>
    </div>
  </Container>
</section>
