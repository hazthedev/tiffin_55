---
import Container from '../components/Container.astro';
import ScrollReveal from '../components/ScrollReveal';
---

<section class="relative py-16 sm:py-24 bg-cream-paper overflow-hidden">
  <div class="absolute inset-0 bg-halftone-cream pointer-events-none opacity-70"></div>

  <Container class="relative">
    <ScrollReveal client:load>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-7">
      <!-- Tier 1: stacked tiffin (turmeric block) -->
      <div class="block-card bg-turmeric aspect-[4/5] relative overflow-hidden flex items-center justify-center">
        <svg viewBox="0 0 200 260" class="w-3/4 h-auto" aria-label="Stacked mangkuk tingkat" role="img">
          <rect x="80" y="20" width="40" height="10" rx="2" fill="#c9c9c9" stroke="#0E1430" stroke-width="2.5"/>
          <line x1="100" y1="30" x2="100" y2="50" stroke="#0E1430" stroke-width="3"/>
          <rect x="40" y="50" width="120" height="50" rx="3" fill="#fff5e1" stroke="#0E1430" stroke-width="3"/>
          <rect x="36" y="50" width="128" height="9" fill="#c9c9c9" stroke="#0E1430" stroke-width="2.5"/>
          <rect x="40" y="105" width="120" height="50" rx="3" fill="#d83d2c" stroke="#0E1430" stroke-width="3"/>
          <rect x="36" y="105" width="128" height="9" fill="#c9c9c9" stroke="#0E1430" stroke-width="2.5"/>
          <rect x="40" y="160" width="120" height="50" rx="3" fill="#1c3aa9" stroke="#0E1430" stroke-width="3"/>
          <rect x="36" y="160" width="128" height="9" fill="#c9c9c9" stroke="#0E1430" stroke-width="2.5"/>
          <rect x="36" y="215" width="128" height="14" rx="3" fill="#c9c9c9" stroke="#0E1430" stroke-width="3"/>
          <text x="100" y="190" text-anchor="middle" font-family="Bungee" font-size="14" fill="#f6c343">RICE</text>
          <text x="100" y="138" text-anchor="middle" font-family="Bungee" font-size="14" fill="#fff5e1">LAUK</text>
          <text x="100" y="84" text-anchor="middle" font-family="Bungee" font-size="14" fill="#0E1430">SAMBAL</text>
        </svg>
        <span class="absolute top-3 left-3 stamp text-ink-blue !bg-cream-paper">3 Tiers</span>
      </div>

      <!-- Tier 2: spice cluster (chili block) -->
      <div class="block-card bg-chili aspect-[4/5] relative overflow-hidden flex items-center justify-center">
        <svg viewBox="0 0 200 260" class="w-3/4" aria-label="Spice and chili cluster" role="img">
          <!-- chili -->
          <path d="M40 90 Q42 60 60 50 Q72 45 78 60 Q92 78 86 130 Q70 160 50 150 Q34 130 40 90 Z" fill="#f6c343" stroke="#0E1430" stroke-width="3"/>
          <path d="M62 50 Q64 30 80 28 Q86 38 78 60" fill="#6b8e4e" stroke="#0E1430" stroke-width="3"/>
          <!-- cardamom pods -->
          <ellipse cx="130" cy="80" rx="20" ry="32" fill="#6b8e4e" stroke="#0E1430" stroke-width="3"/>
          <ellipse cx="160" cy="110" rx="18" ry="28" fill="#6b8e4e" stroke="#0E1430" stroke-width="3"/>
          <line x1="130" y1="50" x2="130" y2="68" stroke="#0E1430" stroke-width="3"/>
          <line x1="160" y1="84" x2="160" y2="98" stroke="#0E1430" stroke-width="3"/>
          <!-- bowl -->
          <path d="M30 180 Q100 220 170 180 L170 220 Q100 250 30 220 Z" fill="#fff5e1" stroke="#0E1430" stroke-width="3"/>
          <path d="M30 180 Q100 200 170 180" stroke="#0E1430" stroke-width="3" fill="none"/>
          <circle cx="70" cy="200" r="4" fill="#d83d2c"/>
          <circle cx="100" cy="208" r="4" fill="#1c3aa9"/>
          <circle cx="130" cy="200" r="4" fill="#6b8e4e"/>
        </svg>
        <span class="absolute top-3 left-3 stamp text-ink-blue !bg-cream-paper">Spice</span>
      </div>

      <!-- Tier 3: kettle steaming (cobalt block) -->
      <div class="block-card bg-cobalt aspect-[4/5] relative overflow-hidden flex items-center justify-center">
        <svg viewBox="0 0 200 260" class="w-3/4" aria-label="Steaming kettle" role="img">
          <!-- steam -->
          <path d="M70 30 Q60 50 80 70 Q100 50 90 30" stroke="#fff5e1" stroke-width="3" fill="none" stroke-linecap="round"/>
          <path d="M110 20 Q100 45 120 65 Q140 45 130 20" stroke="#fff5e1" stroke-width="3" fill="none" stroke-linecap="round"/>
          <!-- kettle body -->
          <ellipse cx="100" cy="170" rx="70" ry="56" fill="#c9c9c9" stroke="#0E1430" stroke-width="3"/>
          <ellipse cx="100" cy="115" rx="40" ry="12" fill="#c9c9c9" stroke="#0E1430" stroke-width="3"/>
          <!-- handle -->
          <path d="M80 95 Q100 70 120 95" stroke="#0E1430" stroke-width="4" fill="none"/>
          <!-- spout -->
          <path d="M30 150 L10 130 L20 175 Z" fill="#c9c9c9" stroke="#0E1430" stroke-width="3"/>
          <!-- decoration -->
          <rect x="55" y="155" width="90" height="12" fill="#f6c343" stroke="#0E1430" stroke-width="2.5"/>
          <text x="100" y="165" text-anchor="middle" font-family="Bungee" font-size="11" fill="#0E1430">TEH·KOPI</text>
          <circle cx="100" cy="190" r="4" fill="#d83d2c"/>
          <!-- base -->
          <rect x="50" y="220" width="100" height="14" rx="3" fill="#0E1430"/>
        </svg>
        <span class="absolute top-3 left-3 stamp text-ink-blue !bg-cream-paper">Hot Brew</span>
      </div>
    </div>

    <div class="mt-12 text-center max-w-2xl mx-auto">
      <p class="font-display text-2xl sm:text-4xl text-ink-blue leading-tight">Three tiers. Three flavors. <span class="text-chili">One table.</span></p>
      <p class="mt-4 text-ink-blue/70 font-medium">
        The mangkuk tingkat isn't a gimmick. It's how we remember meals tasted at home — slow, generous, shared.
      </p>
    </div>
    </ScrollReveal>
  </Container>
</section>
