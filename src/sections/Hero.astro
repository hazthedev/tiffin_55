---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import StaggerHero from '../components/StaggerHero';
---

<section class="relative min-h-dvh flex items-center justify-center overflow-hidden bg-charcoal">
  <!-- Background image with overlay -->
  <div class="absolute inset-0">
    <img
      src="/images/tiffin/tiffin-hero.jpg"
      alt="Mangkuk tingkat being unstacked at Tiffin 55"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-charcoal/70"></div>
  </div>

  <!-- Content -->
  <Container class="relative z-10 py-32">
    <div class="max-w-3xl">
      <StaggerHero client:load delay={0.1}>
        <p class="text-copper text-xs sm:text-sm font-semibold uppercase tracking-[0.25em] mb-4">
          Wangsa Maju &middot; Open till 5am
        </p>
      </StaggerHero>
      <StaggerHero client:load delay={0.2}>
        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-cream leading-[1.05] tracking-tight">
          Kampung flavors.<br />
          <span class="text-copper">City vibes.</span>
        </h1>
      </StaggerHero>
      <StaggerHero client:load delay={0.35}>
        <p class="mt-6 text-base sm:text-lg text-cream/80 max-w-xl leading-relaxed">
          Authentic Malay food, served the way grandma did — stacked, hot, and made for sharing.
        </p>
      </StaggerHero>
      <StaggerHero client:load delay={0.5}>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button variant="primary" href="/menu">See the Menu</Button>
          <Button variant="outline" href="/story#visit">Find Us</Button>
        </div>
      </StaggerHero>
    </div>

    <!-- Decorative handwritten tagline -->
    <div class="absolute bottom-10 right-5 sm:right-10 lg:right-16 rotate-[-6deg]">
      <p class="font-accent text-2xl sm:text-3xl text-copper opacity-90">
        meet &middot; mingle &middot; makan
      </p>
    </div>
  </Container>
</section>
