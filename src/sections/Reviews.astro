---
import Container from '../components/Container.astro';
import ScrollReveal from '../components/ScrollReveal';
import reviewsData from '../data/reviews.json';

const { reviews } = reviewsData;

function stars(count: number) {
  return Array.from({ length: 5 }, (_, i) =>
    i < count
      ? '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#d83d2c" stroke="#0E1430" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>'
      : '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#fff5e1" stroke="#0E1430" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>'
  ).join('');
}
---

<section class="relative py-16 sm:py-24 bg-turmeric overflow-hidden border-y-4 border-ink-blue">
  <div class="absolute inset-0 bg-halftone pointer-events-none opacity-40"></div>

  <Container class="relative">
    <ScrollReveal client:load>
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="stamp text-cobalt" data-anime="stamp">Diners speak</span>
        <div class="mt-6 inline-flex items-center gap-3 chrome-rim border-2 border-ink-blue px-6 py-3">
          <span class="font-display text-3xl text-ink-blue">4.6</span>
          <span class="font-mono text-sm text-ink-blue/70">/ 5</span>
        </div>
        <h2 class="mt-6 font-display text-4xl sm:text-5xl text-ink-blue leading-tight">
          900+ diners on <span class="text-chili">Google.</span>
        </h2>
        <p class="mt-4 text-ink-blue/70 font-medium">They keep coming back. Here's why.</p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
      {reviews.map((review, i) => (
        <div class={`block-card p-6 ${i % 3 === 0 ? 'bg-cream-paper' : i % 3 === 1 ? 'bg-cobalt text-cream-paper' : 'bg-chili text-cream-paper'} relative`}>
          <!-- Quotation mark -->
          <span class="absolute -top-4 -left-3 font-display text-5xl bg-ink-blue text-turmeric w-12 h-12 inline-flex items-center justify-center border-2 border-ink-blue">"</span>
          <div class="flex gap-1 mb-4" set:html={stars(review.rating)} />
          <p class={`text-sm leading-relaxed font-medium ${i % 3 === 0 ? 'text-ink-blue' : 'text-cream-paper'}`}>"{review.quote}"</p>
          <div class="mt-5 flex items-center justify-between border-t-2 border-current pt-3 opacity-90">
            <span class="font-display text-xs uppercase tracking-wider">{review.name}</span>
            <span class="font-mono text-xs">{review.date}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <ScrollReveal client:load delay={0.2}>
        <a
          href="https://g.co/kgs/tiffin55"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 chrome-rim border-2 border-ink-blue px-6 py-3 font-display text-xs uppercase tracking-[0.2em] chrome-shine"
        >
          Read more on Google
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
      </ScrollReveal>
    </div>
  </Container>
</section>
