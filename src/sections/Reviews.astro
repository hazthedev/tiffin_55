---
import Container from '../components/Container.astro';
import ScrollReveal from '../components/ScrollReveal';
import reviewsData from '../data/reviews.json';

const { reviews } = reviewsData;

function stars(count: number) {
  return Array.from({ length: 5 }, (_, i) =>
    i < count
      ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-mustard-gold"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>'
      : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-concrete-grey"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>'
  ).join('');
}
---

<section class="py-16 sm:py-24 bg-coal-brown">
  <Container>
    <ScrollReveal client:load>
    <div class="text-center mb-12">
      <p class="font-mono text-copper text-lg sm:text-xl">4.6 / 5</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl font-bold text-cream">from 900+ diners on Google</h2>
      <p class="mt-3 text-cream/60">They keep coming back. Here's why.</p>
    </div>
    </ScrollReveal>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {reviews.map((review) => (
        <div class="p-6 rounded-sm bg-charcoal border border-concrete-grey/10">
          <div class="flex gap-1 mb-4" set:html={stars(review.rating)} />
          <p class="text-cream/80 text-sm leading-relaxed italic">"{review.quote}"</p>
          <div class="mt-5 flex items-center justify-between">
            <span class="text-sm font-medium text-cream">{review.name}</span>
            <span class="text-xs text-cream/40">{review.date}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-10 text-center">
      <ScrollReveal client:load delay={0.2}>
      <a
        href="https://g.co/kgs/tiffin55"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 text-sm font-medium text-copper hover:text-cream transition-colors"
      >
        Read more on Google
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>
      </ScrollReveal>
    </div>
  </Container>
</section>
