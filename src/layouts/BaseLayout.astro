---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title,
  description = 'Authentic kampung Malay food served in traditional mangkuk tingkat. Open till 3am, everyday. Halal Muslim-owned cafe in Wangsa Maju. Rated 4.6/5 by 900+ diners.',
  image = '/og-image.jpg',
  canonical,
} = Astro.props;

const siteUrl = 'https://tiffin55.vercel.app';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical || siteUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `${siteUrl}${image}`} />
    <meta property="og:url" content={canonical || siteUrl} />
    <meta property="og:type" content="restaurant" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `${siteUrl}${image}`} />

    <!-- JSON-LD Restaurant Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "Tiffin 55",
      "image": `${siteUrl}/og-image.jpg`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "55, Jalan Wangsa Delima 5",
        "addressLocality": "Wangsa Maju",
        "addressRegion": "Kuala Lumpur",
        "addressCountry": "MY"
      },
      "telephone": "+60123456789",
      "servesCuisine": ["Malaysian", "Malay"],
      "priceRange": "$",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          "opens": "11:00",
          "closes": "03:00"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.6",
        "reviewCount": "900"
      }
    })} />
  </head>
  <body class="min-h-dvh antialiased">
    <slot />
    <!-- anime.js via CDN — used opportunistically by sections (spin/shine accents) -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/animejs@3.2.1/lib/anime.min.js"></script>
    <script is:inline>
      (function () {
        if (typeof window === 'undefined' || !window.anime) return;
        // Tiffin tin spin accents already use CSS; anime.js adds gentle wobble to elements with [data-anime="wobble"]
        const wobble = document.querySelectorAll('[data-anime="wobble"]');
        if (wobble.length) {
          window.anime({
            targets: wobble,
            rotate: [
              { value: -3, duration: 800 },
              { value: 3, duration: 800 },
              { value: 0, duration: 600 },
            ],
            loop: true,
            direction: 'alternate',
            easing: 'easeInOutSine',
          });
        }
        // Stamp pop-in
        const stamps = document.querySelectorAll('[data-anime="stamp"]');
        if (stamps.length) {
          window.anime({
            targets: stamps,
            scale: [0.4, 1],
            rotate: [-12, 0],
            opacity: [0, 1],
            duration: 700,
            delay: window.anime.stagger(120),
            easing: 'easeOutBack',
          });
        }
      })();
    </script>
  </body>
</html>
